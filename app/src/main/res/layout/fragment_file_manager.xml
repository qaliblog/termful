<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar with breadcrumb and actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <!-- Home button -->
        <ImageButton
            android:id="@+id/home_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_home"
            android:contentDescription="@string/action_go_home"
            app:tint="?attr/colorOnPrimary" />

        <!-- Breadcrumb -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/breadcrumb_recycler"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:orientation="horizontal" />

        <!-- Search button -->
        <ImageButton
            android:id="@+id/search_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_search"
            android:contentDescription="@string/action_search"
            app:tint="?attr/colorOnPrimary" />

        <!-- Sort/View options -->
        <ImageButton
            android:id="@+id/sort_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_sort"
            android:contentDescription="@string/action_sort"
            app:tint="?attr/colorOnPrimary" />

    </LinearLayout>

    <!-- Search bar (hidden by default) -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="?attr/colorSurface"
        android:elevation="2dp"
        android:visibility="gone"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <EditText
            android:id="@+id/search_edit_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_search_files"
            android:background="@null"
            android:maxLines="1"
            android:imeOptions="actionSearch" />

        <ImageButton
            android:id="@+id/close_search_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/action_close_search"
            app:tint="?attr/colorOnSurface" />

    </LinearLayout>

    <!-- Main content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- File list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/files_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_folder_open"
                android:alpha="0.5"
                app:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/empty_folder"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.7" />

        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/loading_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Action panel for selected files -->
    <LinearLayout
        android:id="@+id/action_panel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="?attr/colorSecondary"
        android:elevation="8dp"
        android:visibility="gone"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/selected_count_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 selected"
            android:textColor="?attr/colorOnSecondary"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/action_copy"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_copy"
            android:contentDescription="@string/action_copy"
            app:tint="?attr/colorOnSecondary" />

        <ImageButton
            android:id="@+id/action_cut"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_cut"
            android:contentDescription="@string/action_cut"
            app:tint="?attr/colorOnSecondary" />

        <ImageButton
            android:id="@+id/action_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            android:contentDescription="@string/action_delete"
            app:tint="?attr/colorOnSecondary" />

        <ImageButton
            android:id="@+id/action_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="@string/action_more"
            app:tint="?attr/colorOnSecondary" />

    </LinearLayout>

    <!-- FAB for new file/folder -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_new"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="@string/action_new_file_folder"
        app:backgroundTint="?attr/colorSecondary"
        app:tint="?attr/colorOnSecondary" />

</LinearLayout>