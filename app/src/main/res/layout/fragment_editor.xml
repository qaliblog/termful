<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Editor Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <!-- File name -->
        <TextView
            android:id="@+id/file_name_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/no_file_open"
            android:textColor="?attr/colorOnPrimary"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="start" />

        <!-- Modified indicator -->
        <TextView
            android:id="@+id/modified_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="?attr/colorSecondary"
            android:textSize="20sp"
            android:visibility="gone"
            android:layout_marginEnd="8dp" />

        <!-- Undo -->
        <ImageButton
            android:id="@+id/undo_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_undo"
            android:contentDescription="@string/action_undo"
            android:enabled="false"
            app:tint="?attr/colorOnPrimary" />

        <!-- Redo -->
        <ImageButton
            android:id="@+id/redo_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_redo"
            android:contentDescription="@string/action_redo"
            android:enabled="false"
            app:tint="?attr/colorOnPrimary" />

        <!-- Save -->
        <ImageButton
            android:id="@+id/save_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_save"
            android:contentDescription="@string/action_save"
            android:enabled="false"
            app:tint="?attr/colorOnPrimary" />

        <!-- Menu -->
        <ImageButton
            android:id="@+id/editor_menu_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="@string/action_editor_menu"
            app:tint="?attr/colorOnPrimary" />

    </LinearLayout>

    <!-- Editor status bar -->
    <LinearLayout
        android:id="@+id/editor_status_bar"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:background="?attr/colorSurfaceVariant"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/cursor_position_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Line 1, Col 1"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/file_encoding_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UTF-8"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/language_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plain Text"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <!-- Main editor area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Code Editor -->
        <com.amrdeveloper.codeview.CodeView
            android:id="@+id/code_editor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top|start"
            android:inputType="textMultiLine|textNoSuggestions"
            android:scrollbars="vertical|horizontal" />

        <!-- No file open state -->
        <LinearLayout
            android:id="@+id/no_file_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_edit"
                android:alpha="0.5"
                app:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/no_file_open"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/open_file_from_manager"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.7"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- External change notification -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/external_change_notification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:visibility="gone"
            app:cardElevation="8dp"
            app:cardBackgroundColor="?attr/colorSecondaryContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_warning"
                    app:tint="?attr/colorOnSecondaryContainer" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/file_changed_externally"
                    android:textColor="?attr/colorOnSecondaryContainer" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/reload_file_button"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/action_reload"
                    style="@style/Widget.Material3.Button.TextButton"
                    app:backgroundTint="@android:color/transparent" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- Find/Replace bar (hidden by default) -->
    <LinearLayout
        android:id="@+id/find_replace_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceVariant"
        android:elevation="4dp"
        android:visibility="gone"
        android:padding="8dp">

        <!-- Find row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/find_edit_text"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="@string/hint_find"
                android:background="@drawable/edit_text_background"
                android:paddingHorizontal="12dp"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/find_previous_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_keyboard_arrow_up"
                android:contentDescription="@string/action_find_previous"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/find_next_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_keyboard_arrow_down"
                android:contentDescription="@string/action_find_next"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/close_find_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/action_close_find"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Replace row (when enabled) -->
        <LinearLayout
            android:id="@+id/replace_row"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/replace_edit_text"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="@string/hint_replace"
                android:background="@drawable/edit_text_background"
                android:paddingHorizontal="12dp"
                android:maxLines="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/replace_button"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/action_replace"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/replace_all_button"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/action_replace_all"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>